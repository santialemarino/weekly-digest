{
  "name": "@zerf/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=.env --watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/server.js",
    "find-ids": "tsx --env-file=.env src/core/find-ids.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "check": "tsc --noEmit && eslint src/ && prettier --check src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cors": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.0.0",
    "marked": "^17.0.3",
    "nodemailer": "^8.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "puppeteer": "^24.37.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/nodemailer": "^7.0.10",
    "prisma": "^6.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
