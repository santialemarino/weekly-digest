# ────────────────────────────────────────────────────────────────────────
# Weekly Digest — Environment Variables
# ────────────────────────────────────────────────────────────────────────

# ── Required: API tokens ────────────────────────────────────────────────

# Slack Bot OAuth token (starts with xoxb-).
# Scopes needed: channels:read, channels:history, groups:read, groups:history, chat:write
SLACK_BOT_TOKEN=

# ClickUp personal API token.
# Get it from: ClickUp → Settings → Apps → API Token
CLICKUP_API_TOKEN=

# Anthropic API key (starts with sk-ant-).
# Get it from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Required: DB Credentials ────────────────────────────────────────────
DATABASE_URL=

# ── Required: Slack digest channel ──────────────────────────────────────

# Channel name (with #) or ID where the digest will be posted.
# The bot must be invited to this channel.
SLACK_DIGEST_CHANNEL=

# ── Required: ClickUp space mapping ─────────────────────────────────────

# Maps project names → ClickUp space IDs (JSON).
# Ensures ClickUp tasks are grouped under the correct project name.
# Example: CLICKUP_SPACE_MAP={"Project1": "C0XXXXX1A", "Project2": "C0XXXXX2A"}
CLICKUP_SPACE_MAP=

# ── Required: Slack channel grouping ────────────────────────────────────

# Maps project names → Slack channel IDs (JSON).
# All channels for the same project are merged into one block in the digest.
# Example: SLACK_CHANNEL_GROUPS={"Project1": ["C0XXXXX1A", "C0XXXXX1B"], "Project2": ["C0XXXXX2A"]}
SLACK_CHANNEL_GROUPS=


# ── (Optional) Output drivers (toggle on/off) ───────────────────────────
# Each output is independent — enable as many as you want.

# Save digest as a local markdown file in digests/ folder. Default: true
OUTPUT_LOCAL_FILE=

# Post digest to the Slack channel defined in SLACK_DIGEST_CHANNEL. Default: true
OUTPUT_SLACK_CHANNEL=

# Send digest as a Slack DM to specific users. Default: false
OUTPUT_SLACK_DM=

# Comma-separated Slack user IDs to DM (only when OUTPUT_SLACK_DM=true).
OUTPUT_SLACK_DM_USERS=

# Send digest via email. Default: false
OUTPUT_EMAIL=


# ── (Optional) Output format per driver ─────────────────────────────────
# Each delivery driver can send the digest in a specific format.
# Available formats: markdown (md), html, json, txt (plain text)

# Which formats to save locally in digests/ folder (comma-separated).
# Default: all formats (md,html,json,txt).
OUTPUT_LOCAL_FILE_FORMATS=

# Format for the Slack channel post. Default: markdown.
# Slack renders markdown natively, so "markdown" is recommended.
OUTPUT_SLACK_CHANNEL_FORMAT=

# Format for Slack direct messages. Default: markdown.
OUTPUT_SLACK_DM_FORMAT=

# Format for the email body. Default: html.
# "html" renders beautifully in Gmail/Outlook and includes a plain text fallback.
# "pdf" would be a good choice too as an attached file
OUTPUT_EMAIL_FORMAT=


# ── (Optional) Tone format per driver ───────────────────────────────────
# Controls the writing style of the report per output driver.
# "informal" = casual, emoji-rich, teammate-friendly (default for Slack)
# "formal"   = polished, professional, no emojis (default for email / clients)

# Tone for local file output. Set to "all" to save both tones in sub-folders.
OUTPUT_LOCAL_FILE_TONE=

# Tone for the Slack channel post. Defaults to "informal" - ideal for inter-company reports.
OUTPUT_SLACK_CHANNEL_TONE=

# Tone for Slack direct messages. Defaults to "informal" - ideal for inter-company reports.
OUTPUT_SLACK_DM_TONE=

# Tone for email. Defaults to "formal" — ideal for client-facing reports.
OUTPUT_EMAIL_TONE=


# ── (Optional) PDF generation ───────────────────────────────────────────
# Generate a PDF version of the digest (uses headless Chrome via puppeteer).
# Default: true. Set to false to skip PDF and speed up execution.
OUTPUT_PDF=

# Attach the PDF to emails when OUTPUT_EMAIL is enabled.
# Default: true.
OUTPUT_EMAIL_ATTACH_PDF=


# ── (Optional) Email SMTP config (only needed if OUTPUT_EMAIL=true) ─────

# Comma-separated recipient email addresses.
OUTPUT_EMAIL_TO=

# Sender email address (the "From" field).
OUTPUT_EMAIL_FROM=

# SMTP server host (e.g. smtp.gmail.com, smtp.office365.com).
OUTPUT_EMAIL_SMTP_HOST=

# SMTP server port. Common: 587 (STARTTLS), 465 (SSL). Default: 587.
OUTPUT_EMAIL_SMTP_PORT=

# SMTP authentication credentials.
# For Gmail: use an App Password (not your regular password).
OUTPUT_EMAIL_SMTP_USER=
OUTPUT_EMAIL_SMTP_PASS=


# ── Optional: Report language ───────────────────────────────────────────

# Language for the generated report (section names, content).
# Options: "es" (Spanish, default), "en" (English)
# REPORT_LANG=

# ── Optional: Sprint offset ─────────────────────────────────────────────

# 0 = current sprint (default). 1 = previous sprint, 2 = two sprints ago, etc.
# When offset > 0, Slack lookback matches the sprint period and the report
# title changes from "Weekly Digest" to "Sprint Report".
# SPRINT_OFFSET=

# ── Optional: Anthropic model ───────────────────────────────────────────

# Which Claude model to use. Defaults to claude-sonnet-4-20250514 if not set.
# Options: claude-sonnet-4-20250514, claude-3-5-haiku-20241022, etc.
# ANTHROPIC_MODEL=

# Model for for tasks that don't need the full power (cheaper/faster). Defaults to claude-3-5-haiku-20241022 
# ANTHROPIC_MODEL_SMALL=

# Auto-select smaller model for small contexts (<20 total items)
# ANTHROPIC_AUTO_MODEL=  


# ── Optional: Auto-discovery mode ───────────────────────────────────────

# Set to true to auto-discover Slack channels by name prefix instead of
# manually listing channel IDs in SLACK_CHANNEL_GROUPS.
# When true, SLACK_PROJECT_PREFIXES is required (JSON mapping project → prefixes).
# USE_SLACK_SECTIONS=
# SLACK_PROJECT_PREFIXES=

# ── Optional: Log level ─────────────────────────────────────────────────

# Controls logger verbosity. Default: info.
# Options (most → least verbose): trace, debug, info, warn, error, fatal
# Use "debug" to see per-channel details, thread counts, folder names, etc.
# LOG_LEVEL=
